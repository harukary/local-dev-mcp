# Optional: API key for direct HTTP access (curl, Claude Code, Cursor, etc.).
# ChatGPT does not support API key auth -- OAuth is needed for that.
# Leave empty or unset to disable.
# Generate one with: node -e "console.log('lvd_' + require('crypto').randomBytes(24).toString('base64url'))"
LOCAL_DEV_MCP_API_KEY=

# Required for OAuth authorization in ChatGPT connection setup.
# Generate one with: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
LOCAL_DEV_MCP_PASSPHRASE=

# Optional OAuth access token TTL in seconds. Default is 30 days.
LOCAL_DEV_MCP_ACCESS_TOKEN_TTL_SECONDS=

# Public origin used in tool results that need browser-renderable URLs.
# Set this to your controlled HTTPS tunnel origin when connecting ChatGPT Apps.
LOCAL_DEV_MCP_PUBLIC_ORIGIN=

# Optional Cloudflare Tunnel settings used by scripts/tunnel.sh.
LOCAL_DEV_MCP_CLOUDFLARE_TUNNEL_ID=
LOCAL_DEV_MCP_CLOUDFLARE_CREDENTIALS_FILE=
